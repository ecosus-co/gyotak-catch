# gyotak-catch environment variables

# Hex-encoded wallet seed (generate with scripts/gen-seed.mjs).
WALLET_SEED=

# Cloudflare D1 HTTP API token (Account-scoped, with D1:Edit permission).
# Used by scripts/mirror-pending.ts to read/update catch_report_images rows.
CF_API_TOKEN=

# Auth token for the line-harness Cloudflare Worker (gyotak namespace).
# Used by scripts/realign-d1-with-chain.ts. Rotate if leaked.
WORKER_TOKEN=

# Optional overrides (defaults target the Midnight preview network).
# INDEXER_URI=
# INDEXER_WS_URI=
# NODE_URI=
# PROOF_SERVER_URI=http://127.0.0.1:6300
# DEBUG_LEVEL=info
