{
  "name": "gyotak-catch",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build:contract": "compact compile contracts/gyotak-catch.compact contracts/managed",
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "preview": "node --no-warnings --experimental-specifier-resolution=node --loader ts-node/esm src/preview.ts",
    "preprod": "PATH=/home/takuya/.local/node22/bin:$PATH NODE_OPTIONS='--max-old-space-size=8192' node --no-warnings --experimental-specifier-resolution=node --loader ts-node/esm src/preprod.ts",
    "deploy": "npm run preview -- deploy",
    "deploy:preprod": "NODE_OPTIONS='--max-old-space-size=8192' npm run preprod -- deploy",
    "deploy:mainnet": "npm run build && node --loader ts-node/esm src/mainnet.ts deploy",
    "record-catch": "npm run preview -- record-catch",
    "record-catch:preprod": "NODE_OPTIONS='--max-old-space-size=8192' npm run preprod -- record-catch",
    "verify-catch": "npm run preview -- verify-catch",
    "verify-catch:preprod": "NODE_OPTIONS='--max-old-space-size=8192' npm run preprod -- verify-catch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
